{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snow Gloves Onboarding",
  "version": "0.1.4",
  "identifier": "com.thoughtseed.snowgloves.onboarding",
  "build": {
    "devUrl": "http://localhost:5180",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Snow Gloves OS \u00b7 Onboarding",
        "width": 920,
        "height": 720,
        "minWidth": 760,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "Developer ID Application: Thoughtseed Private Limited (BS6SZR4929)",
      "minimumSystemVersion": "10.15"
    },
    "category": "DeveloperTool",
    "shortDescription": "Snow Gloves OS onboarding wizard",
    "longDescription": "Provision tenants, verify runtime, and wire your first sources.",
    "publisher": "Thoughtseed Private Limited",
    "copyright": "\u00a9 2026 Thoughtseed Private Limited",
    "homepage": "https://github.com/Sheshiyer/snow-gloves-os"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzODUyNzhFRTMwMjVDQjcKUldTM1hBTGpqaWVGczVZTmx5THVtSFpYK29YWnM0WTBzbEE5OGV4ejVGVnQxeDdyUWprVmtFTHAK",
      "endpoints": [
        "https://github.com/Sheshiyer/snow-gloves-os/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
