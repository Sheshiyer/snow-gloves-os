{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snow Gloves Onboarding",
  "version": "0.1.0",
  "identifier": "com.thoughtseed.snowgloves.onboarding",
  "build": {
    "devUrl": "http://localhost:5180",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "Snow Gloves OS · Onboarding",
      "width": 920,
      "height": 720,
      "minWidth": 760,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false,
      "decorations": true,
      "transparent": false
    }],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
